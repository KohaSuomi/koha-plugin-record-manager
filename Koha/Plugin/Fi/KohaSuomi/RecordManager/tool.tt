<!doctype html>
<html lang="fi">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <title>Record Manager - Työkalut</title>
    <style>
      body {
        background-color: #f8f9fa;
      }
      h1 {
        margin-bottom: 1rem;
      }
      .card {
        margin-top: 1rem;
      }
      .modal-table td, .modal-table th {
        vertical-align: middle;
      }
      .modal-xl .modal-dialog {
        max-width: 90%;
      }
    </style>
    <style>
  /* Korostetaan rivi hover-tilassa */
  table.table-hover tbody tr:hover {
    background-color: #e3f2fd; /* vaaleansininen tausta */
    box-shadow: 2px 2px 5px rgba(0,0,0,0.1); /* pieni varjo */
    transition: all 0.2s ease-in-out;
  }

  /* Varmistetaan, että modaalin taulukko saa saman hover-efektin */
  .modal-table tbody tr:hover {
    background-color: #f1f8e9; /* vaaleanvihreä modaalissa */
    box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
    transition: all 0.2s ease-in-out;
  }
</style>
  </head>
  <body class="p-4">

    <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/mainpage.pl">Etusivu</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Liitännäiset</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Record Manager</a></li>
            <li class="breadcrumb-item active" aria-current="page">Työkalut</li>
          </ol>
        </nav>

        <div id="recordManagerApp">
            <h1>Record Manager - Työkalut</h1>

            <!-- Virheilmoitus -->
            <div v-if="error" class="alert alert-danger text-center" role="alert">
                {{ error }}
            </div>

            <!-- Latausspinneri -->
            <div v-if="loading" class="text-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Ladataan...</span>
                </div>
                <div class="mt-2">Ladataan tietueita...</div>
            </div>

            <!-- Kortti taulukolle -->
            <div v-if="!loading" class="card shadow-sm">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Tietueet</h5>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-bordered table-striped table-hover mb-0">
                      <thead class="table-light">
                          <tr>
                              <th>Tietue</th>
                              <th>Kontrollikentät</th>
                              <th>Emo</th>
                              <th>Toiminnot</th>
                          </tr>
                      </thead>
                      <tbody>
                          <tr v-for="content in contents" :key="content.id">
                              <td>{{ content.author }}, {{ content.title }}</td>
                              <td>{{ content.control_number}}</td>
                              <td>{{ content.host_item }}</td>
                              <td>
                                <button type="button" class="btn btn-primary btn-sm" 
                                        @click="fetchPossibleHosts(content.id)" 
                                        data-bs-toggle="modal" data-bs-target="#possibleHostsModal">
                                  Etsi emoa
                                </button>
                              </td>
                          </tr>
                      </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Modal -->
            <div class="modal fade" id="possibleHostsModal" tabindex="-1" aria-labelledby="possibleHostsModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title" id="possibleHostsModalLabel">Mahdolliset emotietueet</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Sulje"></button>
                        </div>
                        <div class="modal-body">
                    <!-- Latausspinneri modaalin aikana -->
                    <div v-if="loading_modal" class="text-center my-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Ladataan...</span>
                        </div>
                        <div class="mt-2">Ladataan tietueita...</div>
                    </div>

                    <!-- Tulokset tai "Ei osumia" -->
                    <div v-else>
                        <!-- Jos ei tuloksia -->
                        <div v-if="possible_hosts.length === 0" class="alert alert-warning text-center" role="alert">
                            Ei osumia
                        </div>

                        <!-- Jos on tuloksia -->
                        <div v-else class="table-responsive">
                            <table class="table table-bordered table-striped table-hover modal-table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Osumatarkkuus</th>
                                        <th>Kontrollikentät</th>
                                        <th>Teoksentiedot</th>
                                        <th>Toiminnot</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr v-for="host in possible_hosts" :key="host.id">
                                        <td>{{ Math.round(host.score) }}%</td>
                                        <td>{{ host.control_number }}</td>
                                        <td>{{ host.author }}, {{ host.title }}, {{ host.isbn }}, {{ host.issn }}</td>
                                        <td>
                                            <a :href="'/cgi-bin/koha/catalogue/detail.pl?biblionumber=' + host.biblionumber" target="_blank" class="btn btn-secondary btn-sm me-2">
                                                Avaa tietue
                                            </a>
                                            <button type="button" class="btn btn-success btn-sm">
                                                Yhdistä
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="[% PLUGIN_PATH %]/js/app.js"></script>
  </body>
</html>