<!doctype html>
<html lang="en">
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

  </head>
  <body class="p-4">

    <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/mainpage.pl">Etusivu</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Liitännäiset</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Record Manager</a></li>
            <li class="breadcrumb-item active" aria-current="page">Työkalut</li>
        </ol>
        </nav>
        <div id="recordManagerApp">
            <h1>Record Manager - Työkalut</h1>
             <div v-if="loading" class="text-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Ladataan...</span>
                </div>
                <div class="mt-2">Ladataan tietueita...</div>
            </div>
            <table v-if="!loading" class="table table-bordered table-striped">
                <thead class="table-light">
                    <tr>
                        <th>Tietuenumero</th>
                        <th>Kontrollikentät</th>
                        <th>Emo</th>
                        <th>Toiminnot</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="content in contents" :key="content.id">
                        <td>{{ content.id }}</td>
                        <td>{{ content.control_number}}</td>
                        <td>{{ content.host_item }}</td>
                        <td>

                        <button type="button" class="btn btn-primary btn-sm" @click="fetchPossibleHosts(content.id)" data-bs-toggle="modal" data-bs-target="#possibleHostsModal">Etsi emoa</button>
                        </td>
                    </tr>
                </tbody>
            </table>
            <!-- Modal -->
            <div class="modal fade" id="possibleHostsModal" tabindex="-1" aria-labelledby="possibleHostsModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="possibleHostsModalLabel">Mahdolliset emotietueet</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sulje"></button>
                        </div>
                        <div class="modal-body">
                            <table class="table table-bordered table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th>Osumatarkkuus</th>
                                        <th>Kontrollikentät</th>
                                        <th>Teoksentiedot</th>
                                        <th>Toiminnot</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr v-for="host in possible_hosts" :key="host.id">
                                        <td>{{ host.score }}</td>
                                        <td>{{ host.control_number }}</td>
                                        <td>{{ host.author }},{{ host.title }}, {{ host.isbn }}, {{ host.issn }}</td>
                                        <td><a :href="'/cgi-bin/koha/catalogue/detail.pl?biblionumber=' + host.biblionumber" target="_blank" class="btn btn-secondary btn-sm">Avaa tietue</a></td>
                                    </tr>
                                
                                </tbody>
                            </table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Sulje</button>
                        </div>
                    </div>
                </div> 
            </div>
        </div>
    </div>

    <!-- Optional JavaScript; choose one of the two! -->

    <!-- Option 1: Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="[% PLUGIN_PATH %]/js/app.js"></script>
    <!-- Option 2: Separate Popper and Bootstrap JS -->
    <!--
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
    -->
  </body>
</html>



