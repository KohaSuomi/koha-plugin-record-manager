<!doctype html>
<html lang="fi">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <title>Record Manager - Työkalut</title>

    <style>
      /* Prosenttilaatikot */
      .score-badge {
          display: inline-block;
          padding: 0.25rem 0.5rem;
          border-radius: 0.25rem;
          min-width: 3rem;
          text-align: center;
          font-weight: 600;
          color: black; /* Prosenttinumeron teksti mustaksi */
      }

      .score-high {
          background-color: #7cc47f; /* vihreä, näkyvä tausta */
      }

      .score-medium {
          background-color: #ffe699; /* keltainen, hillitty tausta */
      }

      body {
        background-color: #f8f9fa;
      }
      h1 {
        margin-bottom: 1rem;
      }
      .card {
        margin-top: 1rem;
      }
      .modal-table td, .modal-table th {
        vertical-align: middle;
      }
      .modal-xl .modal-dialog {
        max-width: 90%;
      }

      /* Hoverefektit */
      table.table-hover tbody tr:hover {
        background-color: #e3f2fd;
        box-shadow: 2px 2px 5px rgba(3, 46, 219, 0.1);
        transition: all 0.2s ease-in-out;
      }

      .modal-table tbody tr:hover {
        background-color: #f1f8e9;
        box-shadow: 2px 2px 5px rgba(217, 48, 48, 0.1);
        transition: all 0.2s ease-in-out;
      }

      th {
        user-select: none;
      }

      th:hover {
        background-color: #e9ecef;
      }

      .table-responsive {
        max-height: 600px;
        overflow-y: auto;
      }

      .table thead th {
        position: sticky;
        top: 0;
        background-color: #f8f9fa;
        z-index: 2;
        box-shadow: 0 2px 2px -1px rgba(0,0,0,0.1);
      }
    </style>
  </head>

  <body class="p-4">
    <div class="container">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/mainpage.pl">Etusivu</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Liitännäiset</a></li>
            <li class="breadcrumb-item"><a href="/cgi-bin/koha/plugins/plugins-home.pl">Record Manager</a></li>
            <li class="breadcrumb-item active" aria-current="page">Työkalut</li>
          </ol>
        </nav>

        <div id="recordManagerApp">
            <h1>Record Manager - Työkalut</h1>

            <!-- Virheilmoitus -->
            <div v-if="error" class="alert alert-danger text-center" role="alert">
                {{ error }}
            </div>

            <!-- Latausspinneri -->
            <div v-if="loading" class="text-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Ladataan...</span>
                </div>
                <div class="mt-2">Ladataan tietueita...</div>
            </div>

            <!-- Kortti taulukolle -->
            <div v-if="!loading" class="card shadow-sm">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Tietueet</h5>
              </div>
              <div class="card-body p-0">

              <div class="card-body">

              <!-- Hakukenttä ja palautusnappi -->
              <div class="mb-3 d-flex gap-2">
                <div class="input-group">
                  <span class="input-group-text">
                    <i class="bi bi-search"></i>
                  </span>
                  <input
                    type="text"
                    class="form-control"
                    placeholder="Hae tietueita..."
                    v-model="searchQuery"
                  >
                  <button 
                    v-if="searchQuery"
                    class="btn btn-outline-secondary"
                    type="button"
                    @click="searchQuery = ''"
                    title="Tyhjennä haku"
                  >
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>

                <button 
                  v-if="sortKey"
                  class="btn btn-outline-secondary"
                  @click="resetSort"
                  title="Palauta järjestys"
                >
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
              </div>
              
              <div class="table-responsive">
                  <table class="table table-bordered table-striped table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                            <th @click="sortBy('author')" style="cursor:pointer">
                                Tietue
                                <i v-if="sortKey === 'author'" :class="sortOrderIcon"></i>
                            </th>

                            <th @click="sortBy('control_number')" style="cursor:pointer">
                                Kontrollikentät
                                <i v-if="sortKey === 'control_number'" :class="sortOrderIcon"></i>
                            </th>

                            <th @click="sortBy('host_item')" style="cursor:pointer">
                                Emo
                                <i v-if="sortKey === 'host_item'" :class="sortOrderIcon"></i>
                            </th>

                            <th>Toiminnot</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr v-for="content in sortedContents" :key="content.id">
                              <td>{{ content.author }}, {{ content.title }}</td>
                              <td>{{ content.control_number}}</td>
                              <td>{{ content.host_item }}</td>
                              <td>
                                <button type="button" class="btn btn-primary btn-sm"
                                        @click="fetchPossibleHosts(content.id)"
                                        data-bs-toggle="modal" data-bs-target="#possibleHostsModal">
                                  <i class="bi bi-search"></i> Etsi emoa
                                </button>
                              </td>
                          </tr>
                      </tbody>
                  </table>
              </div>
            </div>

            <!-- Modal -->
            <div class="modal fade" id="possibleHostsModal" tabindex="-1" aria-labelledby="possibleHostsModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title" id="possibleHostsModalLabel">Mahdolliset emotietueet</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Sulje"></button>
                        </div>
                        <div class="modal-body">
                    <div v-if="loading_modal" class="text-center my-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Ladataan...</span>
                        </div>
                        <div class="mt-2">Ladataan tietueita...</div>
                    </div>

                    <div v-else>
                        <div v-if="possible_hosts.length === 0" class="alert alert-warning text-center" role="alert">
                            Ei osumia
                            <button type="button" class="btn btn-danger btn-sm" @click="deleteRecord()">
                              <i class="bi bi-trash me-1"></i> Poista tietue
                            </button>
                        </div>

                        <div v-else class="table-responsive">
                         <div class="bg-light border rounded p-2 mb-3">
                          <strong>{{ componentpart.title }}</strong><br>
                          <span class="text-muted">{{ componentpart.author }}</span>
                         </div>
                            <table class="table table-bordered table-striped table-hover modal-table mb-0">
                                <thead class="table-light">
                                  <tr>
                                      <th>Osumatarkkuus</th>
                                      <th>Kontrollikenttä</th>
                                      <th>Tietue</th>
                                      <th>Toiminnot</th>
                                  </tr>
                                </thead>
                                <tbody>
                                    <tr v-for="host in possible_hosts" :key="host.id">
                                        <td>
                                            <span :class="scoreClass(host.score)">
                                                {{ Math.round(host.score) }}%
                                            </span>
                                        </td>
                                        <td>{{ host.control_number }}</td>
                                        <td>{{ host.author }}, {{ host.title }}, {{ host.isbn }}, {{ host.issn }}</td>
                                        <td>
                                            <a :href="'/cgi-bin/koha/catalogue/detail.pl?biblionumber=' + host.biblionumber"
                                              target="_blank"
                                              class="btn btn-secondary btn-sm me-2">
                                              <i class="bi bi-box-arrow-up-right me-1"></i> Avaa tietue
                                            </a>
                                            <button type="button" class="btn btn-success btn-sm" @click="combineToHost(host.biblionumber)">
                                                <i class="bi bi-link-45deg me-1"></i> Yhdistä
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="[% PLUGIN_PATH %]/js/app.js"></script>
    
  </body>
</html>